{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "solarmapp",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://**"]
      }
    },
    "bundle": {
      "active": true,
      "category": "Utility",
      "copyright": "© 2026 Luis Nieto · luisnietofoto.com",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.luisnietofoto.solarmapp",
      "longDescription": "Simulador de posición solar y sombras para fotógrafos. Calcula la trayectoria del sol, horas doradas, azimut y proyección de sombras sobre el mapa.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "minimumSystemVersion": "10.15",
        "signingIdentity": null,
        "providerShortName": null
      },
      "resources": [],
      "shortDescription": "Simulador solar para fotógrafos",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "webviewInstallMode": {
          "type": "downloadBootstrapper"
        }
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Spanish", "English"],
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/128x128.png",
        "sidebarImage": "icons/128x128@2x.png",
        "license": null,
        "installMode": "currentUser"
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "solarmapp — Simulador Solar",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "fileDropEnabled": false
      }
    ]
  }
}
